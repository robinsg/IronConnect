# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# IBMI_HOST: The hostname or IP address of the IBM i server.
IBMI_HOST=

# IBMI_USER: The user name for authentication (stored in environment, NOT in Git).
IBMI_USER=

# IBMI_PASSWORD: The password for authentication (stored in environment, NOT in Git).
IBMI_PASSWORD=

# IBMI_SSL: Set to 'true' to enable SSL encryption for the TN5250 session.
IBMI_SSL=false

# IBMI_DEVICE_NAME: The fixed device name (DEVNAME) for the TN5250 session.
IBMI_DEVICE_NAME=

# IBMI_DEVICE_TYPE: The virtual terminal type (e.g. IBM-3477-FC).
IBMI_DEVICE_TYPE=IBM-3477-FC

# IBMI_MAP: The language map (UK English is 285).
IBMI_MAP=285
